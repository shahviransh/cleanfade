{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CleanFade",
  "version": "0.1.0",
  "identifier": "com.shahviransh.cleanfade",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CleanFade",
        "width": 980,
        "height": 720,
        "resizable": true,
        "label": "main"
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "bin/cleanfade-engine"
    ]
  }
}
